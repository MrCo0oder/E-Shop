<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetEnd="@+id/end"
        motion:constraintSetStart="@id/start"
        motion:duration="1000">
        <KeyFrameSet></KeyFrameSet>
        <OnSwipe />
    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@+id/logoutimageView"
            motion:layout_constraintStart_toEndOf="@+id/view4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            motion:layout_constraintBottom_toBottomOf="@+id/view4"
            android:alpha="0"
            android:layout_marginStart="24dp"
            motion:layout_constraintTop_toTopOf="@+id/view4" />
        <Constraint
            android:id="@+id/logoutimageView"
            motion:layout_constraintStart_toEndOf="@+id/view4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            motion:layout_constraintBottom_toBottomOf="@+id/view4"
            android:alpha="0"
            android:layout_marginStart="24dp"
            motion:layout_constraintTop_toTopOf="@+id/view4" />
        <Constraint
            android:id="@+id/editimageView"
            motion:layout_constraintEnd_toStartOf="@+id/view4"
            android:layout_width="0dp"
            android:layout_height="0dp"
            motion:layout_constraintBottom_toBottomOf="@+id/view4"
            motion:layout_constraintVertical_bias="0.533"
            android:layout_marginEnd="24dp"
            android:alpha="0"
            motion:layout_constraintTop_toTopOf="@+id/view4" />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@+id/logoutimageView"
            motion:layout_constraintStart_toEndOf="@+id/view4"
            android:layout_width="24dp"
            android:layout_height="24dp"
            motion:layout_constraintBottom_toBottomOf="@+id/view4"
            android:alpha="1"
            android:layout_marginStart="24dp"
            motion:layout_constraintTop_toTopOf="@+id/view4" />
        <Constraint
            android:id="@+id/editimageView"
            motion:layout_constraintEnd_toStartOf="@+id/view4"
            android:layout_width="24dp"
            android:layout_height="24dp"
            motion:layout_constraintBottom_toBottomOf="@+id/view4"
            motion:layout_constraintVertical_bias="0.533"
            android:layout_marginEnd="24dp"
            android:alpha="1"
            motion:layout_constraintTop_toTopOf="@+id/view4" />
    </ConstraintSet>
</MotionScene>